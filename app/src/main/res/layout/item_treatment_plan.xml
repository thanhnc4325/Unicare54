<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_profile"
        android:backgroundTint="@color/white"
        android:padding="16dp"
        android:elevation="1dp">

        <!-- Medicine Name -->
        <TextView
            android:id="@+id/tv_medicine_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hydrocortisone"
            android:textColor="#6D28D9"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <!-- Method & Times per day -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="Cách dùng:"
                android:textColor="#6B7280"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_method"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bôi ngoài da - 2 lần / ngày"
                android:textColor="#1F2937"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Purpose -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="Mục đích:"
                android:textColor="#6B7280"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_purpose"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Giảm mẩn đỏ, ngứa da"
                android:textColor="#1F2937"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Guide -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="Hướng dẫn:"
                android:textColor="#6B7280"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_guide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thoa một lớp mỏng lên vùng da bị tổn thương vào buổi sáng và tối."
                android:textColor="#4B5563"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
