<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F1F5F9"
    tools:context=".feature.patients.home.ui.NotificationFragment">

    <!-- Header Curved Area -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_home_header"
        android:paddingTop="28dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="20dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thông báo"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvUnreadCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="0 thông báo chưa đọc"
                android:textColor="#C6DBFF"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Read All Button -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnReadAll"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#2AFFFFFF"
            app:strokeWidth="0dp"
            app:cardElevation="0dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="12dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_verified"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Đọc hết"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </RelativeLayout>

    <!-- Filters ScrollView (Horizontal Tabs) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingVertical="12dp"
        android:paddingHorizontal="20dp"
        android:clipToPadding="false"
        android:background="#F1F5F9">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Tab: Tất cả -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tabAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="#0B5CFF"
                app:strokeWidth="0dp"
                app:cardElevation="0dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tvTabAll"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Tất cả"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Tab: Lịch khám -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tabLichKham"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="0dp"
                app:cardElevation="0dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tvTabLichKham"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Lịch khám"
                    android:textColor="#475569"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Tab: Tiêm chủng -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tabTiemChung"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="0dp"
                app:cardElevation="0dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tvTabTiemChung"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Tiêm chủng"
                    android:textColor="#475569"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Tab: Kết quả -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tabKetQua"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="0dp"
                app:cardElevation="0dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tvTabKetQua"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Kết quả"
                    android:textColor="#475569"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Notification RecyclerView -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvNotifications"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="20dp"
            android:clipToPadding="false"
            android:paddingBottom="24dp" />
            
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</LinearLayout>