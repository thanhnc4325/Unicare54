<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA"
    android:fitsSystemWindows="true">

    <!-- Header Toolbar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        android:elevation="2dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="false"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@drawable/outline_arrow_back_24" />


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Thông tin lượt khám"
            android:textColor="#1F2937"
            android:textSize="18sp"
            android:paddingTop="23dp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Doctor Information Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_profile"
                android:backgroundTint="@color/white"
                android:padding="16dp"
                android:elevation="1dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tv_doctor_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bác sĩ: BS. Nguyễn Văn An"
                    android:textColor="#1F2937"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_doctor_specialty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chuyên khoa: Tim mạch"
                    android:textColor="#4B5563"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Detailed Information List -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_profile"
                android:backgroundTint="@color/white"
                android:padding="16dp"
                android:elevation="1dp"
                android:layout_marginBottom="24dp">

                <!-- Row 1: Ngày khám -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">
                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Ngày khám:"
                        android:textColor="#6B7280"
                        android:textSize="15sp" />
                    <TextView
                        android:id="@+id/tv_appointment_date"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="25/12/2024 09:00"
                        android:textColor="#1F2937"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Row 2: Tên người đặt lịch -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">
                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Người đặt lịch:"
                        android:textColor="#6B7280"
                        android:textSize="15sp" />
                    <TextView
                        android:id="@+id/tv_patient_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nguyễn Bông Min"
                        android:textColor="#1F2937"
                        android:textSize="15sp" />
                </LinearLayout>

                <!-- Row 3: Ngày sinh -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">
                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Ngày sinh:"
                        android:textColor="#6B7280"
                        android:textSize="15sp" />
                    <TextView
                        android:id="@+id/tv_patient_dob"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="21/12/2005"
                        android:textColor="#1F2937"
                        android:textSize="15sp" />
                </LinearLayout>

                <!-- Row 4: Số điện thoại -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">
                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Số điện thoại:"
                        android:textColor="#6B7280"
                        android:textSize="15sp" />
                    <TextView
                        android:id="@+id/tv_patient_phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0987654321"
                        android:textColor="#1F2937"
                        android:textSize="15sp" />
                </LinearLayout>

                <!-- Row 5: Lý do khám -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">
                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Lý do khám:"
                        android:textColor="#6B7280"
                        android:textSize="15sp" />
                    <TextView
                        android:id="@+id/tv_appointment_reason"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Da mẩn đỏ"
                        android:textColor="#1F2937"
                        android:textSize="15sp" />
                </LinearLayout>

                <!-- Row 6: Trạng thái -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Trạng thái:"
                        android:textColor="#6B7280"
                        android:textSize="15sp" />
                    <TextView
                        android:id="@+id/tv_appointment_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Chờ khám"
                        android:textColor="#6366F1"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Bottom Action Buttons -->
            <LinearLayout
                android:id="@+id/layout_doctor_buttons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8dp">

                <!-- button Xem bệnh án -->
                <Button
                    android:id="@+id/btn_view_medical_record"
                    android:layout_width="105dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#3059E0"
                    android:text="Bệnh án"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:cornerRadius="25dp" />

                <!-- button Xem phác đồ điều trị -->
                <Button
                    android:id="@+id/btn_view_treatment_plan"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="185dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Xem phác đồ điều trị"
                    android:textAllCaps="false"
                    android:textColor="#285DD9"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:cornerRadius="25dp"
                    app:strokeColor="#284ED9"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_vaccine_note"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:text="Lưu ý trước &amp; sau tiêm"
                android:textAllCaps="false"
                android:textColor="#059669"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:cornerRadius="27dp"
                app:strokeColor="#10B981"
                app:strokeWidth="2dp"
                app:icon="@drawable/outline_notifications_24"
                app:iconTint="#059669"
                app:iconGravity="textStart" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
